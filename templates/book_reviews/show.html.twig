{% extends 'base.html.twig' %}

{% block title %}BookReviews{% endblock %}

{% block body %}
    <h1>BookReviews</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ book_review.id }}</td>
            </tr>
            <tr>
                <th>Rating</th>
                <td>{{ book_review.rating }}</td>
            </tr>
            <tr>
                <th>Comment</th>
                <td>{{ book_review.comment }}</td>
            </tr>
            <tr>
                <th>Created_at</th>
                <td>{{ book_review.createdAt ? book_review.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_book_reviews_index') }}">back to list</a>

    <a href="{{ path('app_book_reviews_edit', {'id': book_review.id}) }}">edit</a>

    {{ include('book_reviews/_delete_form.html.twig') }}
{% endblock %}
