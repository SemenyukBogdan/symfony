{% extends 'base.html.twig' %}

{% block title %}Readers{% endblock %}

{% block body %}
    <h1>Readers</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ reader.id }}</td>
            </tr>
            <tr>
                <th>Full_name</th>
                <td>{{ reader.fullName }}</td>
            </tr>
            <tr>
                <th>Phone</th>
                <td>{{ reader.phone }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ reader.email }}</td>
            </tr>
            <tr>
                <th>Registration_date</th>
                <td>{{ reader.registrationDate ? reader.registrationDate|date('Y-m-d') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_readers_index') }}">back to list</a>

    <a href="{{ path('app_readers_edit', {'id': reader.id}) }}">edit</a>

    {{ include('readers/_delete_form.html.twig') }}
{% endblock %}
