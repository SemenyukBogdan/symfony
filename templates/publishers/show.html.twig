{% extends 'base.html.twig' %}

{% block title %}Publishers{% endblock %}

{% block body %}
    <h1>Publishers</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ publisher.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ publisher.name }}</td>
            </tr>
            <tr>
                <th>Country</th>
                <td>{{ publisher.country }}</td>
            </tr>
            <tr>
                <th>Founded_year</th>
                <td>{{ publisher.foundedYear }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_publishers_index') }}">back to list</a>

    <a href="{{ path('app_publishers_edit', {'id': publisher.id}) }}">edit</a>

    {{ include('publishers/_delete_form.html.twig') }}
{% endblock %}
