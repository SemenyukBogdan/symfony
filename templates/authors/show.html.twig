{% extends 'base.html.twig' %}

{% block title %}Authors{% endblock %}

{% block body %}
    <h1>Authors</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ author.id }}</td>
            </tr>
            <tr>
                <th>First_name</th>
                <td>{{ author.firstName }}</td>
            </tr>
            <tr>
                <th>Second_name</th>
                <td>{{ author.secondName }}</td>
            </tr>
            <tr>
                <th>Birth_date</th>
                <td>{{ author.birthDate ? author.birthDate|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Country</th>
                <td>{{ author.country }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_authors_index') }}">back to list</a>

    <a href="{{ path('app_authors_edit', {'id': author.id}) }}">edit</a>

    {{ include('authors/_delete_form.html.twig') }}
{% endblock %}
