{% extends 'base.html.twig' %}

{% block title %}Returns index{% endblock %}

{% block body %}
    <h1>Returns index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for return in returns %}
            <tr>
                <td>{{ return.id }}</td>
                <td>
                    <a href="{{ path('app_returns_show', {'id': return.id}) }}">show</a>
                    <a href="{{ path('app_returns_edit', {'id': return.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="2">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_returns_new') }}">Create new</a>
{% endblock %}
