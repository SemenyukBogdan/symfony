{% extends 'base.html.twig' %}

{% block title %}Borrowings{% endblock %}

{% block body %}
    <h1>Borrowings</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ borrowing.id }}</td>
            </tr>
            <tr>
                <th>BorrowDate</th>
                <td>{{ borrowing.borrowDate ? borrowing.borrowDate|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>DueDate</th>
                <td>{{ borrowing.dueDate ? borrowing.dueDate|date('Y-m-d') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_borrowings_index') }}">back to list</a>

    <a href="{{ path('app_borrowings_edit', {'id': borrowing.id}) }}">edit</a>

    {{ include('borrowings/_delete_form.html.twig') }}
{% endblock %}
